generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum CompanyStatus {
  DISCOVERED
  ENRICHING
  READY
  NEEDS_REVIEW
  ARCHIVED
}

enum SourceProvider {
  GOOGLE_PLACES
  APOLLO
  BUILTWITH
  NEWS_API
  FIRECRAWL
  OPENAI
  SNOV_IO
  HUNTER
  MANUAL_SEED
  SYSTEM
}

enum EnrichmentStage {
  GOOGLE_PLACES_DISCOVERY
  APOLLO_COMPANY_ENRICHMENT
  APOLLO_PEOPLE_ENRICHMENT
  FIRECRAWL_EXTRACTION
  PAIN_HYPOTHESIS_GENERATION
  LEAD_SCORING
  LEAD_MAGNET_GENERATION
  OUTREACH_GENERATION
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
  CANCELLED
}

enum DiagnosticFormResponseStatus {
  NOT_SHARED
  LINK_ATTACHED
  RESPONDED
  REVIEWED
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum ExternalSyncStatus {
  NOT_READY
  READY
  SYNCED
  FAILED
}

enum WorkspaceConnectionStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum LinkedInTaskStatus {
  MANUAL_LOOKUP_NEEDED
  READY_TO_SEND
  SENT
  REPLIED
  SKIPPED
}

enum OutreachDraftType {
  INITIAL
  FOLLOW_UP
}

enum EngagementEventType {
  OPEN
  CLICK
  ASSET_VIEW
  REPLY
}

enum CrawlPageType {
  HOMEPAGE
  SERVICES
  ABOUT
  CONTACT
  PRICING
  BLOG
  NEWS
  REVIEWS
  OTHER
}

model Company {
  id                   String           @id @default(cuid())
  name                 String
  website              String?
  phone                String?
  normalizedDomain     String?          @map("normalized_domain")
  industry             String?
  employeeCount        Int?             @map("employee_count")
  description          String?
  locationSummary      String?          @map("location_summary")
  googlePlaceId        String?          @unique @map("google_place_id")
  apolloOrganizationId String?          @unique @map("apollo_organization_id")
  status               CompanyStatus    @default(DISCOVERED)
  manualReviewRequired Boolean          @default(false) @map("manual_review_required")
  sourceConfidence     Float?           @map("source_confidence")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  contacts             Contact[]
  locations            CompanyLocation[]
  technologyProfiles   TechnologyProfile[]
  newsMentions         NewsMention[]
  crawlPages           CrawlPage[]
  painHypotheses       PainHypothesis[]
  leadScores           LeadScore[]
  leadMagnets          LeadMagnet[]
  outreachDrafts       OutreachDraft[]
  linkedinTasks        LinkedInTask[]
  engagementEvents     OutreachEngagementEvent[]
  batchLeads           BatchLead[]
  diagnosticForms      DiagnosticFormBlueprint[]
  sourceEvents         SourceEvent[]
  enrichmentJobs       EnrichmentJob[]

  @@index([name])
  @@index([normalizedDomain])
  @@index([status])
  @@map("companies")
}

model Contact {
  id                     String        @id @default(cuid())
  companyId              String        @map("company_id")
  fullName               String        @map("full_name")
  firstName              String?       @map("first_name")
  lastName               String?       @map("last_name")
  title                  String?
  email                  String?
  phone                  String?
  department             String?
  seniority              String?
  apolloPersonId         String?       @unique @map("apollo_person_id")
  decisionMakerConfidence Float?       @map("decision_maker_confidence")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  company                Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outreachDrafts         OutreachDraft[]
  linkedinTasks          LinkedInTask[]
  engagementEvents       OutreachEngagementEvent[]
  sourceEvents           SourceEvent[]

  @@index([companyId])
  @@index([email])
  @@map("contacts")
}

model CompanyLocation {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  label       String?
  country     String?
  region      String?
  city        String?
  postalCode  String?  @map("postal_code")
  latitude    Float?
  longitude   Float?
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_locations")
}

model TechnologyProfile {
  id             String         @id @default(cuid())
  companyId      String         @map("company_id")
  provider       SourceProvider
  technologyName String         @map("technology_name")
  category       String?
  evidenceUrl    String?        @map("evidence_url")
  confidence     Float?
  rawPayload     Json?          @map("raw_payload")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("technology_profiles")
}

model NewsMention {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  title       String
  summary     String?
  sourceName  String?  @map("source_name")
  articleUrl  String   @map("article_url")
  publishedAt DateTime? @map("published_at")
  confidence  Float?
  rawPayload  Json?    @map("raw_payload")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("news_mentions")
}

model CrawlPage {
  id          String        @id @default(cuid())
  companyId   String        @map("company_id")
  provider    SourceProvider
  pageType    CrawlPageType @map("page_type")
  url         String
  title       String?
  markdown    String?
  html        String?
  summary     String?
  confidence  Float?
  extractedAt DateTime?     @map("extracted_at")
  rawPayload  Json?         @map("raw_payload")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([pageType])
  @@map("crawl_pages")
}

model PainHypothesis {
  id                        String   @id @default(cuid())
  companyId                 String   @map("company_id")
  primaryPain               String   @map("primary_pain")
  secondaryPains            Json     @map("secondary_pains")
  evidence                  Json
  businessImpact            String   @map("business_impact")
  confidenceScore           Float    @map("confidence_score")
  recommendedServiceAngle   String   @map("recommended_service_angle")
  recommendedLeadMagnetType String   @map("recommended_lead_magnet_type")
  insufficientEvidence      Boolean  @default(false) @map("insufficient_evidence")
  modelProvider             SourceProvider? @map("model_provider")
  modelName                 String?  @map("model_name")
  rawPayload                Json?    @map("raw_payload")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  company                   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  diagnosticForms           DiagnosticFormBlueprint[]

  @@index([companyId])
  @@map("pain_hypotheses")
}

model LeadScore {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  totalScore      Int      @map("total_score")
  componentScores Json     @map("component_scores")
  explanation     String
  modelProvider   SourceProvider? @map("model_provider")
  modelName       String?  @map("model_name")
  rawPayload      Json?    @map("raw_payload")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("lead_scores")
}

model LeadMagnet {
  id                      String   @id @default(cuid())
  companyId               String   @map("company_id")
  title                   String
  type                    String
  summary                 String
  whyItMatchesTheLead     String   @map("why_it_matches_the_lead")
  suggestedDeliveryFormat String   @map("suggested_delivery_format")
  estimatedTimeToPrepare  String   @map("estimated_time_to_prepare")
  rawPayload              Json?    @map("raw_payload")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  company                 Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("lead_magnets")
}

model OutreachDraft {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  contactId         String?  @map("contact_id")
  emailSubject1     String   @map("email_subject_1")
  emailSubject2     String   @map("email_subject_2")
  coldEmailShort    String   @map("cold_email_short")
  coldEmailMedium   String   @map("cold_email_medium")
  linkedinMessageSafe String @map("linkedin_message_safe")
  followUp1         String   @map("follow_up_1")
  followUp2         String   @map("follow_up_2")
  draftType         OutreachDraftType @default(INITIAL) @map("draft_type")
  sequenceStep      Int      @default(1) @map("sequence_step")
  parentDraftId     String?  @map("parent_draft_id")
  approvalStatus    ApprovalStatus @default(PENDING_APPROVAL) @map("approval_status")
  approvalNotes     String?  @map("approval_notes")
  approvedAt        DateTime? @map("approved_at")
  rawPayload        Json?    @map("raw_payload")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact           Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  gmailDraftLink    GmailDraftLink?
  sheetSyncRecords  SheetSyncRecord[]
  linkedinTask      LinkedInTask?
  parentDraft       OutreachDraft? @relation("OutreachDraftFollowUps", fields: [parentDraftId], references: [id], onDelete: SetNull)
  childDrafts       OutreachDraft[] @relation("OutreachDraftFollowUps")
  engagementEvents  OutreachEngagementEvent[]

  @@index([companyId])
  @@index([contactId])
  @@index([approvalStatus])
  @@index([draftType])
  @@index([parentDraftId])
  @@map("outreach_drafts")
}

model OutreachEngagementEvent {
  id              String              @id @default(cuid())
  outreachDraftId String              @map("outreach_draft_id")
  companyId       String              @map("company_id")
  contactId       String?             @map("contact_id")
  eventType       EngagementEventType @map("event_type")
  followUpCreated Boolean             @default(false) @map("follow_up_created")
  payload         Json?
  occurredAt      DateTime            @default(now()) @map("occurred_at")
  outreachDraft   OutreachDraft       @relation(fields: [outreachDraftId], references: [id], onDelete: Cascade)
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact         Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([outreachDraftId])
  @@index([companyId])
  @@index([contactId])
  @@index([eventType])
  @@map("outreach_engagement_events")
}

model LinkedInTask {
  id                    String             @id @default(cuid())
  companyId             String             @map("company_id")
  contactId             String?            @map("contact_id")
  outreachDraftId       String             @unique @map("outreach_draft_id")
  status                LinkedInTaskStatus @default(MANUAL_LOOKUP_NEEDED)
  contactName           String?            @map("contact_name")
  contactTitle          String?            @map("contact_title")
  linkedinProfileUrl    String?            @map("linkedin_profile_url")
  lookupHints           Json?              @map("lookup_hints")
  connectionRequestNote String             @map("connection_request_note")
  dmMessage             String             @map("dm_message")
  followUpDm            String             @map("follow_up_dm")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  company               Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact               Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  outreachDraft         OutreachDraft      @relation(fields: [outreachDraftId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@map("linkedin_tasks")
}

model SourceEvent {
  id         String         @id @default(cuid())
  companyId  String?        @map("company_id")
  contactId  String?        @map("contact_id")
  provider   SourceProvider
  eventType  String         @map("event_type")
  fieldName  String?        @map("field_name")
  sourceUrl  String?        @map("source_url")
  snippet    String?
  confidence Float?
  payload    Json?
  createdAt  DateTime       @default(now()) @map("created_at")
  company    Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact?       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([contactId])
  @@index([provider])
  @@map("source_events")
}

model EnrichmentJob {
  id            String          @id @default(cuid())
  companyId     String?         @map("company_id")
  provider      SourceProvider?
  stage         EnrichmentStage
  status        JobStatus       @default(PENDING)
  attempts      Int             @default(0)
  requestedBy   String?         @map("requested_by")
  lastError     String?         @map("last_error")
  payload       Json?
  resultSummary Json?           @map("result_summary")
  runAt         DateTime?       @map("run_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  company       Company?        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([stage])
  @@index([status])
  @@map("enrichment_jobs")
}

model LeadBatch {
  id                 String     @id @default(cuid())
  industry           String
  region             String
  requestedLeadCount Int        @map("requested_lead_count")
  status             JobStatus  @default(PENDING)
  autoRunPipeline    Boolean    @default(true) @map("auto_run_pipeline")
  completedCompanies Int        @default(0) @map("completed_companies")
  failedCompanies    Int        @default(0) @map("failed_companies")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  leads              BatchLead[]

  @@index([status])
  @@map("lead_batches")
}

model BatchLead {
  id         String    @id @default(cuid())
  batchId    String    @map("batch_id")
  companyId  String    @map("company_id")
  status     JobStatus @default(PENDING)
  lastError  String?   @map("last_error")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  batch      LeadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([batchId, companyId])
  @@index([batchId])
  @@index([companyId])
  @@index([status])
  @@map("batch_leads")
}

model DiagnosticFormBlueprint {
  id                      String                 @id @default(cuid())
  companyId               String                 @map("company_id")
  painHypothesisId        String?                @map("pain_hypothesis_id")
  industry                String
  primaryGoal             String                 @map("primary_goal")
  qualificationStrength   String                 @map("qualification_strength")
  estimatedCompletionTime String                 @map("estimated_completion_time")
  formTitle               String                 @map("form_title")
  formIntro               String                 @map("form_intro")
  closingMessage          String                 @map("closing_message")
  outreachCtaShort        String                 @map("outreach_cta_short")
  outreachCtaMedium       String                 @map("outreach_cta_medium")
  formSections            Json                   @map("form_sections")
  rawPayload              Json?                  @map("raw_payload")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")
  company                 Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  painHypothesis          PainHypothesis?        @relation(fields: [painHypothesisId], references: [id], onDelete: SetNull)
  formLink                DiagnosticFormLink?

  @@index([companyId])
  @@index([painHypothesisId])
  @@map("diagnostic_form_blueprints")
}

model DiagnosticFormLink {
  id             String                       @id @default(cuid())
  blueprintId    String                       @unique @map("blueprint_id")
  url            String
  responseStatus DiagnosticFormResponseStatus @default(NOT_SHARED) @map("response_status")
  responseSummary Json?                       @map("response_summary")
  scoreImpact    Json?                        @map("score_impact")
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")
  blueprint      DiagnosticFormBlueprint      @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  @@index([responseStatus])
  @@map("diagnostic_form_links")
}

model GmailDraftLink {
  id             String             @id @default(cuid())
  outreachDraftId String            @unique @map("outreach_draft_id")
  gmailDraftId   String             @map("gmail_draft_id")
  gmailThreadId  String?            @map("gmail_thread_id")
  syncStatus     ExternalSyncStatus @default(NOT_READY) @map("sync_status")
  lastSyncedAt   DateTime?          @map("last_synced_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  outreachDraft  OutreachDraft      @relation(fields: [outreachDraftId], references: [id], onDelete: Cascade)

  @@index([syncStatus])
  @@map("gmail_draft_links")
}

model SheetSyncRecord {
  id             String             @id @default(cuid())
  outreachDraftId String            @map("outreach_draft_id")
  tabName        String             @map("tab_name")
  rowKey         String             @map("row_key")
  syncStatus     ExternalSyncStatus @default(NOT_READY) @map("sync_status")
  lastSyncedAt   DateTime?          @map("last_synced_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  outreachDraft  OutreachDraft      @relation(fields: [outreachDraftId], references: [id], onDelete: Cascade)

  @@unique([outreachDraftId, tabName])
  @@index([outreachDraftId])
  @@index([syncStatus])
  @@map("sheet_sync_records")
}

model GoogleWorkspaceConnection {
  id                   String                    @id @default(cuid())
  provider             String                    @default("google_workspace")
  email                String?
  scopes               Json
  encryptedAccessToken String?                   @map("encrypted_access_token")
  encryptedRefreshToken String?                  @map("encrypted_refresh_token")
  accessTokenExpiresAt DateTime?                 @map("access_token_expires_at")
  status               WorkspaceConnectionStatus @default(DISCONNECTED)
  lastError            String?                   @map("last_error")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  @@unique([provider])
  @@index([status])
  @@map("google_workspace_connections")
}
